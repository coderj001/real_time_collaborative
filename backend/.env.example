# Server
PORT=4000

# MongoDB
MONGODB_URL=mongodb://localhost:27017/realtime-canvas

# Redis
REDIS_URL=redis://localhost:6379

# Auth — single user
AUTH_USERNAME=admin
AUTH_PASSWORD=password

# Auth — multi-user (alternative to AUTH_USERNAME/AUTH_PASSWORD)
# Comma-separated list of user:password pairs
# AUTH_USERS=alice:secret1,bob:secret2
